	vsrcextract -C external/src/grpc/third_party/abseil-cpp grpc-abseil-cpp-${_grpc_abseil_cpp_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/benchmark grpc-benchmark-${_grpc_benchmark_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/bloaty grpc-bloaty-${_grpc_bloaty_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/boringssl-with-bazel grpc-boringssl-with-bazel-${_grpc_boringssl_with_bazel_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/cares/cares grpc-cares-${_grpc_cares_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/envoy-api grpc-envoy-api-${_grpc_envoy_api_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/googleapis grpc-googleapis-${_grpc_googleapis_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/googletest googletest-${_grpc_googletest_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/opencensus-proto grpc-opencensus-proto-${_grpc_opencensus_proto_gitrev}.tar.gz
	vsrcextract -C external/src/grpc/third_party/opentelemetry grpc-opentelemetry-${_grpc_opentelemetry_gitrev}.tar.gz
